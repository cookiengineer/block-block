{
	"manifest_version": 2,
	"name": "Block Block",
	"version": "1.0",
	"description": "Blocks user hostile CSS properties and JS listeners",
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"browser_action": {
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		},
		"default_title": "Block Block"
	},
	"background": {
		"scripts": ["background.js"],
		"persistent": false
	},
	"browser_specific_settings": {
		"gecko": {
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	},
	"permissions": [
		"<all_urls>",
		"storage"
	],
	"content_scripts": [
		{
			"matches": [
				"<all_urls>"
			],
			"js": [
				"content.js"
			],
			"run_at": "document_idle"
		}
	]
}
